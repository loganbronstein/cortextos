{
  "permissions": {
    "allow": [
      "*"
    ],
    "defaultMode": "bypassPermissions"
  },
  "statusLine": {
    "type": "command",
    "command": "cortextos bus hook-context-status",
    "refreshInterval": 5,
    "timeout": 2
  },
  "hooks": {
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cortextos crash-alert",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cortextos bus hook-loop-detector",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cortextos bus hook-session-restore",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/loganbronstein/cortextos/orgs/cortex/agents/analyst/.claude/hooks/pre-compact-snapshot.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "cortextos bus hook-extract-facts",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
